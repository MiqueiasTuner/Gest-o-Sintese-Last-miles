{
  "entities": {
    "Partner": {
      "title": "Partner",
      "description": "A business partner providing last-mile connectivity services.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Company name" },
        "contact": { "type": "string", "description": "Primary contact person or info" },
        "state": { "type": "string", "description": "State of operation (UF)" },
        "cities": { "type": "string", "description": "Comma-separated list of cities" },
        "logo_url": { "type": "string", "description": "URL to the company logo" },
        "status": { "type": "string", "enum": ["active", "cancelled"], "description": "Operational status" },
        "sla_incidents": { "type": "number", "description": "Total count of SLA violations" },
        "created_at": { "type": "string", "format": "date-time", "description": "Creation timestamp" }
      },
      "required": ["name", "contact", "state", "status"]
    },
    "Point": {
      "title": "Point",
      "description": "An operational point or customer terminal.",
      "type": "object",
      "properties": {
        "customer_name": { "type": "string", "description": "End customer name" },
        "address": { "type": "string", "description": "Full address" },
        "city": { "type": "string", "description": "City" },
        "state": { "type": "string", "description": "State (UF)" },
        "partner_id": { "type": "string", "description": "ID of the responsible partner" },
        "partner_name": { "type": "string", "description": "Denormalized partner name" },
        "cost": { "type": "number", "description": "Operational cost" },
        "status": { "type": "string", "enum": ["pending", "completed", "cancelled"], "description": "Contract status" },
        "payment_status": { "type": "string", "enum": ["pending", "paid"], "description": "Financial status" },
        "sla_status": { "type": "string", "enum": ["within", "warning", "breached"], "description": "Current SLA status" },
        "equipment": { "type": "string", "description": "Equipment model (ONT/Router)" },
        "bandwidth": { "type": "string", "description": "Contracted bandwidth" },
        "created_at": { "type": "string", "format": "date-time", "description": "Creation timestamp" }
      },
      "required": ["customer_name", "address", "city", "state", "partner_id", "cost", "status"]
    },
    "Customer": {
      "title": "Customer",
      "description": "A corporate client or customer record.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Company name or Trade name" },
        "cnpj": { "type": "string", "description": "CNPJ tax ID" },
        "contact": { "type": "string", "description": "Primary contact person" },
        "phone": { "type": "string", "description": "Contact phone number" },
        "email": { "type": "string", "description": "Contact email" },
        "address": { "type": "string", "description": "Business headquarters address" },
        "city": { "type": "string", "description": "Headquarters city" },
        "state": { "type": "string", "description": "Headquarters state (UF)" },
        "created_at": { "type": "string", "format": "date-time", "description": "Creation timestamp" }
      },
      "required": ["name"]
    }
  },
  "firestore": {
    "/partners/{partnerId}": {
      "schema": "Partner",
      "description": "Collection of business partners"
    },
    "/points/{pointId}": {
      "schema": "Point",
      "description": "Collection of operational points/terminals"
    },
    "/customers/{customerId}": {
      "schema": "Customer",
      "description": "Collection of corporate customers"
    }
  }
}
